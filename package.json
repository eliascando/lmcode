{
  "name": "lmcode",
  "version": "0.1.0",
  "private": true,
  "description": "CLI local para programar con LM Studio",
  "bin": {
    "lmcode": "./bin/lmcode.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./bin/lmcode.js",
    "check": "node --check ./bin/lmcode.js",
    "models": "node ./bin/lmcode.js --models",
    "install:local": "./scripts/install-local.sh"
  }
}
